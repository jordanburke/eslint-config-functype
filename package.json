{
  "name": "eslint-config-functype",
  "version": "1.3.0",
  "description": "Curated ESLint flat config bundle for functional TypeScript programming (ESLint 9.x+)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "functype-list-rules": "dist/cli/list-rules.js"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "functional",
    "typescript",
    "immutable"
  ],
  "scripts": {
    "build": "pnpm run typecheck && tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepare": "pnpm run build",
    "list-rules": "node dist/cli/list-rules.js",
    "list-rules:verbose": "node dist/cli/list-rules.js --verbose",
    "list-rules:usage": "node dist/cli/list-rules.js --usage",
    "check-deps": "node dist/cli/list-rules.js --check-deps",
    "cli:help": "node dist/cli/list-rules.js --help",
    "diff": "node dist/cli/list-rules.js --diff"
  },
  "peerDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.38.0 || ^8.39.0 || ^9.0.0",
    "@typescript-eslint/parser": "^8.38.0 || ^8.39.0 || ^9.0.0",
    "eslint": "^10.0.1",
    "eslint-plugin-functional": "^9.0.2",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-plugin-functional": "^9.0.4",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "author": "Jordan Burke",
  "repository": {
    "type": "git",
    "url": "https://github.com/jordanburke/eslint-config-functype"
  },
  "homepage": "https://github.com/jordanburke/eslint-config-functype",
  "bugs": {
    "url": "https://github.com/jordanburke/eslint-config-functype/issues"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a",
  "engines": {
    "node": ">=22.0.0"
  }
}
